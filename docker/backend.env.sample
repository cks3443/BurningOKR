##########################################################
# Production backend environment template                #
# Copy this file to docker/backend.env and edit values.  #
##########################################################

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL connection (internal docker network)
SPRING_DATASOURCE_URL=jdbc:postgresql://burning-okr-postgres:5432/burning_okr?useSSL=false
SPRING_DATASOURCE_USERNAME=burningokr
SPRING_DATASOURCE_PASSWORD=change_me_strong_password
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# JWT resource server issuer URI (must match your IdP realm/tenant)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://keycloak.example.com/realms/burningokr

# Optional SMTP configuration (only needed for mail features)
#SPRING_MAIL_USERNAME=smtp-user
#SPRING_MAIL_PASSWORD=smtp-password
#SPRING_MAIL_HOST=smtp.example.com
#SPRING_MAIL_PORT=587

# OIDC settings exposed to frontend
SYSTEM_CONFIGURATION_OIDC_ADMIN_GROUP_NAME=burningokr-admin
SYSTEM_CONFIGURATION_CLIENT_ID=burning-okr-frontend
SYSTEM_CONFIGURATION_ISSUER_URI=https://keycloak.example.com/realms/burningokr
SYSTEM_CONFIGURATION_SCOPES_0=openid
SYSTEM_CONFIGURATION_SCOPES_1=offline_access
SYSTEM_CONFIGURATION_SCOPES_2=profile
SYSTEM_CONFIGURATION_SCOPES_3=email
SYSTEM_CONFIGURATION_STRICT_DISCOVERY_DOCUMENT_VALIDATION=false
SYSTEM_CONFIGURATION_PROVIDER=keycloak
SYSTEM_CONFIGURATION_DEMO_MODE=false

# Azure AD example
#SYSTEM_CONFIGURATION_OIDC_ADMIN_GROUP_NAME=<azure-admin-group>
#SYSTEM_CONFIGURATION_CLIENT_ID=<azure-client-id>
#SYSTEM_CONFIGURATION_ISSUER_URI=https://login.microsoftonline.com/<tenant-id>/v2.0
#SYSTEM_CONFIGURATION_SCOPES_0=openid
#SYSTEM_CONFIGURATION_SCOPES_1=offline_access
#SYSTEM_CONFIGURATION_SCOPES_2=profile
#SYSTEM_CONFIGURATION_SCOPES_3=email
#SYSTEM_CONFIGURATION_SCOPES_4=<client-id>/.default
#SYSTEM_CONFIGURATION_STRICT_DISCOVERY_DOCUMENT_VALIDATION=false
#SYSTEM_CONFIGURATION_PROVIDER=azureAD
#SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://login.microsoftonline.com/<tenant-id>/v2.0
